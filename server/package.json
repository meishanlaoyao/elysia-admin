{
  "name": "elysia-admin",
  "version": "1.1.0",
  "description": "elysia-admin 基于 Elysia.js 构建，这是一个为 Bun 运行时 深度优化的现代 TypeScript Web 框架。",
  "author": {
    "name": "梅山老妖",
    "email": "1360658549@qq.com",
    "gitee": "https://gitee.com/nian-qian/elysia-admin"
  },
  "license": "MIT",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun run script/build.ts",
    "build:binary": "bun build --compile --minify-whitespace --minify-syntax --minify-identifiers --target bun --outfile ./dist_binary/server ./src/index.ts",
    "db:push": "bun ./script/generate-dbconfig.ts push",
    "db:pull": "bun ./script/generate-dbconfig.ts pull",
    "docker:build": "docker build -t hnq1/elysia-admin:latest .",
    "docker:run": "docker run --name elysia-admin -p 3000:3000 elysia-admin:latest",
    "docker:stop": "docker stop elysia-admin",
    "docker:rm": "docker rm elysia-admin",
    "docker:logs": "docker logs elysia-admin"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/static": "^1.4.7",
    "croner": "^10.0.1",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "ioredis": "^5.8.2",
    "jose": "^6.1.3",
    "nodemailer": "^7.0.11",
    "postgres": "^3.4.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@elysiajs/openapi": "^1.4.11",
    "@types/nodemailer": "^7.0.4",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8"
  },
  "module": "src/index.js"
}