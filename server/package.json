{
  "name": "elysia-admin",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun run script/build.ts",
    "build:binary": "bun build --compile --minify-whitespace --minify-syntax --minify-identifiers --target bun --outfile ./dist_binary/server ./src/index.ts",
    "db:push": " bunx drizzle-kit push",
    "db:pull": " bunx drizzle-kit pull",
    "docker:build": "docker build -t hnq1/xiaomei-elysia-server:latest .",
    "docker:run": "docker run --name xiaomei-elysia-server -p 3000:3000 xiaomei-elysia-server:latest",
    "docker:stop": "docker stop xiaomei-elysia-server",
    "docker:rm": "docker rm xiaomei-elysia-server",
    "docker:logs": "docker logs xiaomei-elysia-server"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/static": "^1.4.7",
    "croner": "^10.0.1",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "ioredis": "^5.8.2",
    "jose": "^6.1.3",
    "nodemailer": "^7.0.11",
    "postgres": "^3.4.7",
    "qcloud-cos-sts": "^3.1.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@elysiajs/openapi": "^1.4.11",
    "@types/nodemailer": "^7.0.4",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.8"
  },
  "module": "src/index.js"
}