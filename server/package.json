{
  "name": "elysia-admin",
  "version": "1.4.5",
  "description": "一个基于 ElysiaJS + Bun + Vue 3 构建的全栈管理后台。",
  "keywords": [
    "Elysia Admin",
    "elysia-admin",
    "elysia admin",
    "elysia后台管理系统",
    "ElysiaJS",
    "elysiajs vue",
    "elysiajs bun",
    "后台管理系统"
  ],
  "author": {
    "name": "梅山老妖",
    "email": "1360658549@qq.com",
    "gitee": "https://gitee.com/nian-qian/elysia-admin",
    "github": "https://github.com/meishanlaoyao/elysia-admin",
    "url": "https://elysia-admin.top"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/nian-qian/elysia-admin"
  },
  "homepage": "https://elysia-admin.top",
  "bugs": "https://gitee.com/nian-qian/elysia-admin/issues",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:workers": "bun run script/build-processors.ts && bun run src/infrastructure/queue/runtime/worker.ts",
    "dev:all": "concurrently -n server,workers -c cyan,yellow \"bun run dev\" \"bun run dev:workers\"",
    "build": "bun run script/build.ts",
    "build:processors": "bun run script/build-processors.ts",
    "db:push": "bun ./script/generate-dbconfig.ts push",
    "db:pull": "bun ./script/generate-dbconfig.ts pull",
    "docker:build": "docker build -t hnq1/elysia-admin:latest .",
    "docker:run": "docker run --name elysia-admin -p 3000:3000 elysia-admin:latest",
    "docker:stop": "docker stop elysia-admin",
    "docker:rm": "docker rm elysia-admin",
    "docker:logs": "docker logs elysia-admin",
    "test": "bun test --preload ./test/preload.ts",
    "test:watch": "bun test --watch --preload ./test/preload.ts",
    "test:coverage": "bun test --coverage --preload ./test/preload.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.21.3",
    "@bull-board/elysia": "^6.21.3",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "bullmq": "^5.76.7",
    "croner": "^10.0.1",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "nodemailer": "^7.0.13",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@elysiajs/openapi": "^1.4.15",
    "@types/nodemailer": "^7.0.11",
    "bun-types": "latest",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10"
  },
  "module": "src/index.js"
}