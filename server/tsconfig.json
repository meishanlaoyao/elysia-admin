{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "types": [
      "bun-types"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@database/*": [
        "./database/*"
      ],
      "database/*": [
        "./database/*"
      ],
      "script/*": [
        "./script/*"
      ]
    },
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "script/**/*.ts",
    "database/**/*.ts",
    "test/**/*.ts"
  ]
}